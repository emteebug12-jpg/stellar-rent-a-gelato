# Soroban RPC endpoint the keeper polls for registered footprints and submits pokes to.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployed RentGelato contract id whose registrations the keeper scans.
RENT_GELATO_CONTRACT_ID=

# Local signing key for the keeper's own Stellar account (funds transaction fees).
# NEVER commit a real secret key. Use a dedicated, funded keeper-only account.
KEEPER_SECRET_KEY=

# Poll interval, in milliseconds, between scan-and-poke cycles.
KEEPER_POLL_INTERVAL_MS=60000

# TTL (in ledgers) below which a registration is considered low and eligible for a poke.
KEEPER_LOW_TTL_THRESHOLD=1000
